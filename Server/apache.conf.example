# Apache2 vhost for hosting Web + Admin + Server on patan.onlinejobportal.org.
# Replaces nginx.conf.example — same routing: / -> Web, /admin -> Admin, /api -> Server (port 7001).
#
# Setup on VPS:
#   sudo systemctl stop nginx && sudo systemctl disable nginx
#   sudo a2enmod proxy proxy_http rewrite headers ssl
#   sudo cp apache.conf.example /etc/apache2/sites-available/nagarpalika.conf
#   sudo a2dissite 000-default.conf
#   sudo a2ensite nagarpalika.conf
#   sudo apache2ctl configtest && sudo systemctl reload apache2
#   sudo certbot --apache -d patan.onlinejobportal.org   # adds :443 block + http->https redirect
#
# Server/.env on the VPS needs (so CORS + redirects match this origin):
#   ALLOWED_ORIGINS=https://patan.onlinejobportal.org
#   PORTAL_URL=https://patan.onlinejobportal.org
#   API_URL=https://patan.onlinejobportal.org/api
#   COOKIE_SECURE=true   <- set true once certbot has HTTPS live, then pm2 restart
#
# Apache runs as www-data — /home/<user> dirs are usually 750, which blocks
# traversal into Server/out/*. Either: chmod o+x on /home/dev-team-np,
# /home/dev-team-np/project, /home/dev-team-np/project/nagarpalika-v2, and
# Server/ (no need to open file contents, just the +x bit for traversal);
# or symlink the out dirs under /var/www/ and point DocumentRoot/Alias there instead.

<VirtualHost *:80>
    ServerName patan.onlinejobportal.org

    DocumentRoot /home/dev-team-np/project/nagarpalika-v2/Server/out/web

    LimitRequestBody 20971520

    <Directory /home/dev-team-np/project/nagarpalika-v2/Server/out/web>
        Options -Indexes +FollowSymLinks
        AllowOverride None
        Require all granted
    </Directory>

    <Directory /home/dev-team-np/project/nagarpalika-v2/Server/out/admin>
        Options -Indexes +FollowSymLinks
        AllowOverride None
        Require all granted
    </Directory>

    # ── API ── proxy to Node/Express via PM2 (ecosystem.config.cjs, port 7001) ──
    ProxyPreserveHost On
    ProxyPass /api/ http://127.0.0.1:7001/api/
    ProxyPassReverse /api/ http://127.0.0.1:7001/api/

    # ── Admin panel ── static build, SPA fallback, base path /admin/ ───────────
    Alias /admin /home/dev-team-np/project/nagarpalika-v2/Server/out/admin
    <Directory /home/dev-team-np/project/nagarpalika-v2/Server/out/admin>
        RewriteEngine On
        RewriteBase /admin/
        RewriteCond %{REQUEST_FILENAME} !-f
        RewriteCond %{REQUEST_FILENAME} !-d
        RewriteRule ^ index.html [L]
    </Directory>

    # ── Web portal ── static build, SPA fallback at root ───────────────────────
    <Directory /home/dev-team-np/project/nagarpalika-v2/Server/out/web>
        RewriteEngine On
        RewriteBase /
        RewriteCond %{REQUEST_FILENAME} !-f
        RewriteCond %{REQUEST_FILENAME} !-d
        RewriteRule ^ index.html [L]
    </Directory>

    ErrorLog ${APACHE_LOG_DIR}/nagarpalika-error.log
    CustomLog ${APACHE_LOG_DIR}/nagarpalika-access.log combined
</VirtualHost>
