# ==============================================================================
# SERVER (Express + MongoDB Backend) — EXAMPLE
# ==============================================================================
# Copy to .env and fill in values: cp .env.example .env

# ── SERVER ────────────────────────────────────────────────────────────────────
PORT=7001
NODE_ENV=development

# ── DATABASE ──────────────────────────────────────────────────────────────────
DATABASE=mongodb://user:password@host:27017/nagarpalika?authSource=admin

# ── SESSION ───────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=replace-with-64-char-random-hex-string

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── JWT AUTHENTICATION ────────────────────────────────────────────────────────
ADMIN_JWT_SECRET_KEY=replace-with-strong-random-secret
EMPLOYEE_JWT_SECRET_KEY=replace-with-strong-random-secret
DOCTOR_JWT_SECRET_KEY=replace-with-strong-random-secret
JWT_EXPIRY=7d

# ── WHATSAPP BUSINESS API ─────────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_OTP_TEMPLATE=otp_verification
WHATSAPP_WEBHOOK_VERIFY_TOKEN=nagarpalika-whatsapp-verify

# ── SMS GATEWAY (OTP fallback after WhatsApp failure) ─────────────────────────
SMS_API_URL=
SMS_API_KEY=
SMS_SENDER_ID=NAGPAL

# ── EMAIL / SMTP ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# ── UIDAI / AADHAAR OTP API (optional — not used in current scope) ─────────────
UIDAI_AUA_CODE=
UIDAI_ASA_LICENSE_KEY=
UIDAI_API_URL=https://auth.uidai.gov.in/

# ── PAYMENT GATEWAY ───────────────────────────────────────────────────────────
PAYMENT_GATEWAY_KEY_ID=
PAYMENT_GATEWAY_KEY_SECRET=
PAYMENT_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── FILE STORAGE (S3 required — no local uploads) ───────────────────────────
MAX_IMAGE_SIZE=5242880
MAX_PHOTO_SIZE=5242880
MAX_SIGNATURE_SIZE=5242880
MAX_DOCUMENT_SIZE=10485760
OTP_MAX_ATTEMPTS=3
OTP_EXPIRE_MINUTES=10
OTP_PER_HOUR_LIMIT=3
# ── AWS S3 (document storage) ─────────────────────────────────────────────────
# When AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY + S3_BUCKET are set, files go to S3.
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_PREFIX=nagarpalika
# Optional CDN/public bucket base (direct image URLs without presigning)
S3_PUBLIC_BASE_URL=

# ── PORTAL URLS ───────────────────────────────────────────────────────────────
PORTAL_URL=http://localhost:5173
API_URL=http://localhost:7001

# ── SECURITY (optional) ───────────────────────────────────────────────────────
ADMIN_ALLOWED_IPS=
CALL_LETTER_TOKEN_SECRET=
ENABLE_MANUAL_PAYMENT_OVERRIDE=false
